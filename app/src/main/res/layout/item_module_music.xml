<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:tools="http://schemas.android.com/tools"
        android:orientation="vertical"
        android:paddingLeft="6dp"
        android:paddingRight="16dp"
        android:paddingBottom="20dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginLeft="10dp"
            android:orientation="horizontal">

        <View
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="3dp"
                android:background="@color/red_e61b19" />

        <TextView
                android:id="@+id/name1"
                android:layout_width="240dp"
                android:layout_height="20dp"
                android:layout_marginLeft="10dp"
                android:gravity="center_vertical"
                tools:text="老师简介"
                android:textColor="@color/black_333333"
                android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

        <ImageButton
                android:id="@+id/playAndPause"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/iconmusic_07" />

        <TextView
                android:id="@+id/time_now"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="2dp"
                android:layout_toLeftOf="@id/seekbar"
                android:gravity="center"
                android:text="00:00:00" />

        <SeekBar
                android:id="@+id/seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_weight="1"
                android:progressDrawable="@drawable/video_progressbar"
                android:thumb="@drawable/shape_circle" />


        <TextView
                android:id="@+id/time_all"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_toRightOf="@id/seekbar"
                android:gravity="center"
                android:text="00:00:00" />

        <com.tencent.rtmp.ui.TXCloudVideoView
                android:id="@+id/video_view"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
    </LinearLayout>
</LinearLayout>